        public static RegionDefinition GetDefinition(RegionId regionId) => AllRegions[regionId];

        public static EvolutionPath GetDefaultPathForRegion(RegionId regionId) => GetDefinition(regionId).DefaultPaths.First();

        public static List<RegionId> ChooseCampaignRegions(RegionId startingRegion, DeterministicRandom rng)
        {
            var chosen = new List<RegionId> { startingRegion };
            var neighbors = new List<RegionId>(GetDefinition(startingRegion).AdjacentRegions);
            while (chosen.Count < SimulationConfig.CampaignRegionCount && neighbors.Count > 0)
            {
                int index = rng.Next(neighbors.Count);
                chosen.Add(neighbors[index]);
                neighbors.RemoveAt(index);
            }

            return chosen;
        }
    }

    public class WorldState
    {
        public static WorldState CurrentGlobalState { get; private set; }

        public ulong Seed { get; private set; }
        public DeterministicRandom Rng { get; private set; }
        public WorldClock Clock { get; private set; }
        public Dictionary<RegionId, RegionState> Regions { get; private set; } = new();
        public PlayerState Player { get; private set; }
        public EconomyState Economy { get; private set; }
        public Dictionary<FactionType, FactionState> Factions { get; private set; } = new();
        public Dictionary<string, ProgressionBarState> ProgressionBars { get; private set; } = new();
        public List<EncounterDefinition> Encounters { get; private set; } = new();
        public List<LongTermEventDefinition> LongTermEvents { get; private set; } = new();
        public List<QuestDefinition> QuestDefinitions { get; private set; } = new();
        public List<string> SimulationHistory { get; private set; } = new();
        public bool ShowLogs { get; set; } = true;
        public bool AutoResolveEncounters { get; set; } = false;
        public int TicksSinceLastEvolution { get; private set; }

        private WorldState(ulong seed, RegionId startingRegion)
        {
            Seed = seed;
            Rng = new DeterministicRandom(seed);
            Clock = new WorldClock();
            Player = new PlayerState(startingRegion);
            Economy = new EconomyState();
            CurrentGlobalState = this;
            TicksSinceLastEvolution = 0;
        }

        public static WorldState CreateCampaign(ulong seed, RegionId startingRegion)
        {
            var state = new WorldState(seed, startingRegion);
            state.InitializeRegions(startingRegion);
            state.InitializeEconomy();
            state.InitializeFactions();
            state.InitializeProgressionBars();
            state.InitializeEncounters();
            state.InitializeLongTermEvents();
            state.InitializeQuestDefinitions();
            state.Log(LogCategory.Simulation, $"Campaign seeded with {seed} starting at {startingRegion}");
            return state;
        }

        private void InitializeRegions(RegionId startingRegion)
        {
            var selected = WorldDefinitions.ChooseCampaignRegions(startingRegion, Rng);
            foreach (var regionId in selected)
            {
                var definition = WorldDefinitions.GetDefinition(regionId);
                var tier = Rng.Probability(SimulationConfig.StartingTier2Chance) ? WorldTier.Tier2 : WorldTier.Tier1;
                var region = new RegionState(definition, tier, EvolutionPath.None);
                region.ProgressionBars = CreateRegionProgressionBars(region);
                region.ZoneEvolutionBars = CreateRegionZoneEvolutionBars(region);
                region.EventBars = CreateRegionEventBars(region);
                region.Settlements = CreateRegionSettlements(region);
                Regions[regionId] = region;
            }
        }

        private Dictionary<string, EventBarState> CreateRegionEventBars(RegionState region)
        {
            var bars = new Dictionary<string, EventBarState>();
            foreach (var definition in EventBarRegistry.AllEventBars)
            {
                bars[definition.Id] = new EventBarState(definition);
            }
            return bars;
        }

        private Dictionary<string, SettlementState> CreateRegionSettlements(RegionState region)
        {
            var settlements = new Dictionary<string, SettlementState>();
            var regionSettlements = SettlementRegistry.AllSettlements.Where(s => s.Region == region.RegionId).ToList();
            foreach (var def in regionSettlements)
            {
                settlements[def.Id] = new SettlementState(def);
                Player.DiscoveredSettlementIds.Add(def.Id);
            }
            return settlements;
        }

        private Dictionary<string, ProgressionBarState> CreateRegionProgressionBars(RegionState region)
        {
            var bars = new Dictionary<string, ProgressionBarState>();
            foreach (var definition in ProgressionBarRegistry.AllRegionBarDefinitions)
            {
                bars[definition.Id] = new ProgressionBarState(definition);
            }
            return bars;
        }

        private Dictionary<string, ZoneEvolutionBarState> CreateRegionZoneEvolutionBars(RegionState region)
        {
            var bars = new Dictionary<string, ZoneEvolutionBarState>();
            var definitions = ZoneEvolutionBarRegistry.GetBarsForRegion(region.RegionId);
            foreach (var definition in definitions)
            {
                bars[definition.Id] = new ZoneEvolutionBarState(definition);
            }
            return bars;
        }

        private void InitializeEconomy()
        {
            Economy.MarketPrices = ItemRegistry.AllItems.ToDictionary(item => item.Id, item => (double)item.BaseValue);
            Economy.UpdatePrices(Rng);
        }

        private void InitializeFactions()
        {
            foreach (var faction in FactionRegistry.AllFactions)
            {
                Factions[faction.Type] = faction;
            }
        }

        private void InitializeProgressionBars()
        {
            foreach (var barDefinition in ProgressionBarRegistry.GlobalBarDefinitions)
            {
                ProgressionBars[barDefinition.Id] = new ProgressionBarState(barDefinition);
            }
        }

        private void InitializeEncounters()
        {
            Encounters = EncounterRegistry.AllEncounters;
        }

        private void InitializeLongTermEvents()
        {
            LongTermEvents = LongTermEventRegistry.AllEvents;
        }

        private void InitializeQuestDefinitions()
        {
            QuestDefinitions = QuestRegistry.AllQuests;
        }

        public IEnumerable<QuestLineDefinition> GetAvailableQuestLines()
        {
            var startedIds = Player.ActiveQuestLines.Select(ql => ql.Definition.Id).ToHashSet();
            return QuestLineRegistry.AllQuestLines.Where(ql => !startedIds.Contains(ql.Id) && ql.CanStart(this));
        }

        public bool StartQuestLine(string questLineId)
        {
            var questLineDef = QuestLineRegistry.AllQuestLines.FirstOrDefault(ql => ql.Id == questLineId);
            if (questLineDef == null || !questLineDef.CanStart(this))
                return false;

            var questLineState = new QuestLineState(questLineDef);
            Player.ActiveQuestLines.Add(questLineState);
            Log(LogCategory.Player, $"Quest line started: {questLineDef.Title}");
            return true;
        }

        public bool CompleteCurrentQuest(string questLineId)
        {
            var questLine = Player.ActiveQuestLines.FirstOrDefault(ql => ql.Definition.Id == questLineId);
            if (questLine == null || questLine.Completed)
                return false;

            var currentQuestId = questLine.GetCurrentQuestId();
            if (currentQuestId == null)
                return false;

            var questDef = QuestRegistry.AllQuests.FirstOrDefault(q => q.Id == currentQuestId);
            if (questDef == null)
                return false;

            questLine.CompletedQuestIds.Add(currentQuestId);

            // Apply quest effects
            if (questDef.Reward.Gold.HasValue)
                Player.Gold += questDef.Reward.Gold.Value;

            foreach (var repChange in questDef.Reward.ReputationChanges)
                Player.Reputation[repChange.Key] += repChange.Value;

            foreach (var effect in questDef.EventBarEffects)
            {
                var targetRegion = effect.TargetRegion ?? Player.CurrentRegion;
                var bar = GetRegionEventBar(targetRegion, effect.BarId);
                if (bar != null)
                    bar.AddProgress(effect.Amount);
            }

            foreach (var (zoneBarId, amount) in questDef.ZoneEvolutionEffects)
                ApplyCurrentRegionZoneEvolutionInfluence(zoneBarId, "Quest", currentQuestId, questDef.Title, amount);

            Log(LogCategory.Player, $"Quest completed: {questDef.Title}");

            // Try to advance to next quest
            if (!questLine.TryAdvanceToNextQuest())
            {
                questLine.Completed = true;
                Log(LogCategory.Player, $"Quest line completed: {questLine.Definition.Title}");
                
                // Apply final rewards
                if (questLine.Definition.FinalReward.Gold.HasValue)
                    Player.Gold += questLine.Definition.FinalReward.Gold.Value;

                questLine.Definition.OnComplete?.Invoke(this);
            }

            return true;
        }

        // ===== LEGACY QUEST METHODS (for backwards compatibility) =====
        public IEnumerable<QuestDefinition> GetAvailableQuests() => new List<QuestDefinition>();
        public bool AcceptQuest(string questId = null) => false;
        public bool TurnInQuest(string questId = null) => false;
        public void CompleteQuestsInTown() { }

        public ProgressionBarState GetRegionProgressionBar(RegionId regionId, string barId)
        {
            return Regions.TryGetValue(regionId, out var region)
                && region.ProgressionBars.TryGetValue(barId, out var bar)
                ? bar
                : null;
        }

        public ProgressionBarState GetCurrentRegionProgressionBar(string barId)
        {
            return GetRegionProgressionBar(Player.CurrentRegion, barId);
        }

        public ZoneEvolutionBarState GetRegionZoneEvolutionBar(RegionId regionId, string barId)
        {
            return Regions.TryGetValue(regionId, out var region)
                && region.ZoneEvolutionBars.TryGetValue(barId, out var bar)
                ? bar
                : null;
        }

        public ZoneEvolutionBarState GetCurrentRegionZoneEvolutionBar(string barId)
        {
            return GetRegionZoneEvolutionBar(Player.CurrentRegion, barId);
        }

        public void ApplyZoneEvolutionInfluence(RegionId regionId, string barId, string sourceType, string sourceId, string sourceName, double amount)
        {
            var bar = GetRegionZoneEvolutionBar(regionId, barId);
            if (bar != null)
            {
                var influence = new ZoneEvolutionInfluence
                {
                    SourceType = sourceType,
                    SourceId = sourceId,
                    SourceName = sourceName,
                    Amount = amount
                };
                bar.AddInfluence(influence, this);
            }
        }

        public void ApplyCurrentRegionZoneEvolutionInfluence(string barId, string sourceType, string sourceId, string sourceName, double amount)
        {
            ApplyZoneEvolutionInfluence(Player.CurrentRegion, barId, sourceType, sourceId, sourceName, amount);
        }

        public EventBarState GetRegionEventBar(RegionId regionId, string barId)
        {
            return Regions.TryGetValue(regionId, out var region)
                && region.EventBars.TryGetValue(barId, out var bar)
                ? bar
                : null;
        }

        public EventBarState GetCurrentRegionEventBar(string barId)
        {
            return GetRegionEventBar(Player.CurrentRegion, barId);
        }

        public SettlementState GetSettlement(string settlementId)
        {
            foreach (var region in Regions.Values)
            {
                if (region.Settlements.TryGetValue(settlementId, out var settlement))
                    return settlement;
            }
            return null;
        }

        public void DiscoverSettlement(string settlementId)
        {
            var settlement = GetSettlement(settlementId);
            if (settlement != null && !settlement.Discovered)
            {
                settlement.Discover();
                Player.DiscoveredSettlementIds.Add(settlementId);
                Log(LogCategory.Player, $"You discovered {settlement.Definition.Name}!");
            }
        }

        public void Log(LogCategory category, string message)
        {
            if (ShowLogs)
                SimulationLog.Write(category, message);

            if (category == LogCategory.Simulation)
                SimulationHistory.Add(message);
        }

        public void LogProgressionBars(string context)
        {
            var touchedBars = new List<string>();

            if (ProgressionBars.TryGetValue("WorldStability", out var worldStability) && worldStability.HasBeenTouched)
            {
                touchedBars.Add($"WorldStability={worldStability.Value:F1}/{worldStability.Definition.Threshold:F0}");
            }

            foreach (var region in Regions.OrderBy(r => r.Key))
            {
                var regionTouched = region.Value.ProgressionBars
                    .Where(kvp => kvp.Value.HasBeenTouched)
                    .OrderBy(kvp => kvp.Key);
                
                foreach (var bar in regionTouched)
                {
                    touchedBars.Add($"{region.Value.Definition.Name}.{bar.Key}={bar.Value.Value:F1}/{bar.Value.Definition.Threshold:F0}");
                }
            }

            if (touchedBars.Count > 0)
            {
                Log(LogCategory.Simulation, $"[PROGRESS] {context}: {string.Join(" | ", touchedBars)}");
            }
        }

        public void LogZoneEvolutionBars(string context)
        {
            var zoneLines = new List<string>();

            foreach (var region in Regions.OrderBy(r => r.Key))
            {
                var bars = region.Value.ZoneEvolutionBars.OrderBy(kvp => kvp.Key);
                foreach (var bar in bars)
                {
                    var milestone = bar.Value.CurrentMilestone;
                    var milestonePercent = milestone switch
                    {
                        ZoneEvolutionMilestone.Milestone1 => "0-25%",
                        ZoneEvolutionMilestone.Milestone2 => "26-50%",
                        ZoneEvolutionMilestone.Milestone3 => "51-75%",
                        ZoneEvolutionMilestone.Milestone4 => "76-100%",
                        _ => "unknown"
                    };
                    zoneLines.Add($"{region.Value.Definition.Name}.{bar.Key}={bar.Value.Value:F1} [{milestonePercent}]");
                }
            }

            if (zoneLines.Count > 0)
            {
                Log(LogCategory.Simulation, $"[ZONES] {context}: {string.Join(" | ", zoneLines)}");
            }
        }

        public void AdvanceWorld(int minutes)
        {
            Clock.AdvanceMinutes(minutes);
            Log(LogCategory.Simulation, $"World advanced by {minutes} minutes. Time is now {Clock.CurrentTime}.");
            for (int i = 0; i < SimulationConfig.WorldUpdateTicksPerAction; i++)
            {
                UpdateEconomy();
                UpdateProgression();
            }

            TicksSinceLastEvolution++;
            if (TicksSinceLastEvolution >= SimulationConfig.EvolutionCheckFrequency)
            {
                TicksSinceLastEvolution = 0;
                CheckEvolution();
            }

            TryTriggerLongTermEvents();
            LogProgressionBars($"after advancing {minutes} minutes");
        }

        private void UpdateEconomy()
        {
            Economy.UpdatePrices(Rng);
            Log(LogCategory.Simulation, "Marketplace prices shifted slightly.");
        }

        private void UpdateProgression()
        {
            foreach (var bar in ProgressionBars.Values)
                bar.ApplyDecay();

            foreach (var region in Regions.Values)
            {
                // Update progression bars
                foreach (var bar in region.ProgressionBars.Values)
                    bar.ApplyDecay();

                // Update zone evolution bars
                foreach (var zoneBar in region.ZoneEvolutionBars.Values)
                {
                    var decayInfluence = new ZoneEvolutionInfluence
                    {
                        SourceType = "Decay",
                        SourceId = "passive",
                        SourceName = "Time passes",
                        Amount = -zoneBar.Definition.DecayAmount
                    };
                    zoneBar.AddInfluence(decayInfluence, this);
                }

                // Update event bars and check for completion
                foreach (var eventBar in region.EventBars.Values)
                {
                    eventBar.ApplyDecay();
                    
                    if (eventBar.ShouldProcessCompletion())
                    {
                        ProcessEventBarCompletion(region, eventBar);
                        eventBar.MarkCompletionProcessed();
                    }
                }
            }

            Log(LogCategory.Simulation, "Progression and event bars decayed according to current conditions.");
            LogProgressionBars("after progression decay");
        }

        private void ProcessEventBarCompletion(RegionState region, EventBarState eventBar)
        {
            var def = eventBar.Definition;
            Log(LogCategory.Simulation, $"EVENT: {def.Name} has completed in {region.Definition.Name}!");

            // Unlock encounters
            foreach (var encounterId in def.OnCompletion.UnlockedEncounterIds)
            {
                Log(LogCategory.Simulation, $"  + Encounter unlocked: {encounterId}");
            }

            // Unlock quest lines
            foreach (var questLineId in def.OnCompletion.UnlockedQuestLineIds)
            {
                Log(LogCategory.Simulation, $"  + Quest line unlocked: {questLineId}");
                // TODO: Actually add to available quest lines when player visits settlement
            }

            // Modify settlements
            foreach (var (settlementId, statType, amount) in def.OnCompletion.SettlementModifications)
            {
                if (region.Settlements.TryGetValue(settlementId, out var settlement))
                {
                    Log(LogCategory.Simulation, $"  + {settlement.Definition.Name} {statType} changed by {amount}");
                    // Settlement modifications handled in settlement system
                }
            }

            // Influence zone evolution
            foreach (var (zoneBarId, amount) in def.OnCompletion.ZoneEvolutionInfluences)
            {
                if (region.ZoneEvolutionBars.TryGetValue(zoneBarId, out var zoneBar))
                {
                    var influence = new ZoneEvolutionInfluence
                    {
                        SourceType = "EventCompletion",
                        SourceId = eventBar.Definition.Id,
                        SourceName = eventBar.Definition.Name,
                        Amount = amount
                    };
                    zoneBar.AddInfluence(influence, this);
                    Log(LogCategory.Simulation, $"  + Zone bar {zoneBarId} influenced by {amount}");
                }
            }

            // Reset cooldown if repeatable
            if (def.Repeatable)
            {
                eventBar.ResetCompletion();
                Log(LogCategory.Simulation, $"  + {def.Name} will trigger again after cooldown");
            }
        }

        private void CheckEvolution()
        {
            foreach (var region in Regions.Values)
            {
                var active = region.ProgressionBars.Values.Where(b => b.Completed).ToList();
                if (active.Count > 0)
                {
                    PromoteRegion(region, active.Count);
                }
            }
        }

        private void PromoteRegion(RegionState region, int completedBars)
        {
            if (region.CurrentTier < WorldTier.Tier5)
            {
                region.CurrentTier = (WorldTier)Math.Min((int)WorldTier.Tier5, (int)region.CurrentTier + 1);
                Log(LogCategory.Simulation, $"{region.Definition.Name} grew more dangerous and advanced to Tier {(int)region.CurrentTier}.");
            }

            if (region.ProgressionBars.Values.Any(bar => bar.Completed))
            {
                var path = WorldDefinitions.GetDefaultPathForRegion(region.RegionId);
                region.CurrentPath = path;
                Log(LogCategory.Simulation, $"{region.Definition.Name} settled into the {path} evolution path.");
            }
        }

        private void TryTriggerLongTermEvents()
        {
            foreach (var longEvent in LongTermEvents.Where(e => !e.HasTriggered).ToList())
            {
                if (longEvent.Condition(this))
                {
                    longEvent.HasTriggered = true;
                    longEvent.OnTrigger(this);
                    Log(LogCategory.Simulation, $"Long-term event triggered: {longEvent.Name}");
                    Log(LogCategory.Player, $"Something changes in the world: {longEvent.Name}.");
                }
            }
        }

        public EncounterDefinition RollEncounter()
        {
            var available = Encounters.Where(e => e.CanOccur(this)).ToList();
            if (available.Count == 0)
                return null;

            // TODO: Implement quest-related encounter filtering with new QuestLine system
            double totalWeight = 0;
            foreach (var encounter in available)
            {
                double weight = encounter.Weight(this);
                totalWeight += weight;
            }

            double pick = Rng.Next((int)(totalWeight * 1000)) / 1000.0;
            double current = 0;
            foreach (var encounter in available)
            {
                double weight = encounter.Weight(this);
                current += weight;
                if (pick <= current)
                    return encounter;
            }

            return available.Last();
        }

        public EncounterResult ResolveEncounter(EncounterDefinition encounter, EncounterOption option)
        {
            var result = option.Execute(this);
            if (result.PlayerVisible)
                Log(LogCategory.Player, result.Message);
            else
                Log(LogCategory.Simulation, result.Message);

            if (result.Success)
            {
                // TODO: Implement quest completion check with new QuestLine system
                // Check if this encounter completes any active quest lines
            }

            return result;
        }

        public void Explore()
        {
            Log(LogCategory.Player, "You venture forth into the surrounding land.");
            AdvanceWorld(SimulationConfig.ExploreMinutes);
            var encounterRoll = Rng.Probability(SimulationConfig.EncounterChance);
            if (encounterRoll)
            {
                var encounter = RollEncounter();
                if (encounter != null)
                {
                    Log(LogCategory.Player, $"Encounter: {encounter.Name} - {encounter.Summary}");
                    PresentEncounter(encounter);
                    return;
                }
            }

            // Try to discover a settlement by RNG
            var region = Regions[Player.CurrentRegion];
            var undiscoveredSettlements = region.Settlements.Values.Where(s => !s.Discovered).ToList();
            if (undiscoveredSettlements.Count > 0 && Rng.Probability(0.30))
            {
                var discoveredSettlement = undiscoveredSettlements[Rng.Next(undiscoveredSettlements.Count)];
                discoveredSettlement.Discover();
                Log(LogCategory.Player, $"Through your exploration, you discover the settlement of {discoveredSettlement.Definition.Name}! It has been added to your fast travel locations.");
                return;
            }

            var discoveryMessage = DiscoverLandmark();
            Log(LogCategory.Player, discoveryMessage);
        }

        private string DiscoverLandmark()
        {
            var region = Regions[Player.CurrentRegion];
            if (region.Definition.Biome == BiomeType.Forest && Rng.Probability(0.25))
                return "You discover an overgrown shrine hidden beneath the trees.";
            if (region.Definition.Biome == BiomeType.Mountain && Rng.Probability(0.20))
                return "You find a narrow pass with carvings of an old dragon cult.";
            if (region.Definition.Biome == BiomeType.Swamp && Rng.Probability(0.20))
                return "You stumble upon a flooded ruin with strange lights.";
            if (Rng.Probability(0.15))
                return "Your exploration reveals a small treasure cache of useful supplies.";
            return "The landscape shifts subtly as you move; nothing remarkable appears yet.";
        }

        private void PresentEncounter(EncounterDefinition encounter)
        {
            if (!ShowLogs || AutoResolveEncounters)
            {
                var autoChoice = encounter.Options[Rng.Next(encounter.Options.Count)];
                ResolveEncounter(encounter, autoChoice);
                return;
            }

            Console.WriteLine();
            Console.WriteLine($"--- {encounter.Name} ---");
            Console.WriteLine(encounter.Summary);
            for (int i = 0; i < encounter.Options.Count; i++)
            {
                Console.WriteLine($"[{i + 1}] {encounter.Options[i].Description}");
            }

            while (true)
            {
                Console.Write("Choose an option: ");
                var input = Console.ReadLine();
                if (int.TryParse(input, out var selection) && selection >= 1 && selection <= encounter.Options.Count)
                {
                    ResolveEncounter(encounter, encounter.Options[selection - 1]);
                    break;
                }

                Console.WriteLine("Invalid selection. Please enter the number of your choice.");
            }

            Console.WriteLine();
        }

        public void Rest()
        {
            var region = Regions[Player.CurrentRegion];
            var activities = GetAvailableRestActivities(region);
            Log(LogCategory.Player, "You take time to rest and recover.");
            foreach (var activity in activities)
            {
                Log(LogCategory.Player, $"- {activity}");
            }

            Player.Heal(SimulationConfig.RestHours * SimulationConfig.RestHealPerHour);
            Log(LogCategory.Player, $"You restore health to {Player.Health:F0}/{Player.MaxHealth}.");
            AdvanceWorld(SimulationConfig.RestHours * 60);
        }

        private List<string> GetAvailableRestActivities(RegionState region)
        {
            var activities = new List<string> { "Sleep", "Meditate", "Sharpen weapons" };
            if (region.Definition.HasWater)
                activities.Add("Fish");
            if (region.Definition.HasTown)
                activities.Add("Visit the tavern");
            activities.Add("Read a book");
            return activities;
        }

        public bool Travel(RegionId destination)
        {
            if (!Regions.ContainsKey(destination))
            {
                Log(LogCategory.Player, "That destination is not part of your current campaign.");
                return false;
            }

            if (destination == Player.CurrentRegion)
            {
                Log(LogCategory.Player, "You are already in that region.");
                return false;
            }

            var region = Regions[Player.CurrentRegion];
            Log(LogCategory.Player, $"You prepare to leave {region.Definition.Name}.");
            Log(LogCategory.Player, "You are about to leave this region. Returning will no longer be possible.");

            string input;
            if (AutoResolveEncounters)
            {
                input = "y";
            }
            else
            {
                Console.Write("Confirm travel? (y/n): ");
                input = Console.ReadLine()?.Trim().ToLower();
            }

            if (input != "y")
            {
                Log(LogCategory.Player, "You decide to stay for now.");
                return false;
            }

            region.IsLocked = true;
            Player.CurrentRegion = destination;
            Log(LogCategory.Player, $"You travel to {Regions[destination].Definition.Name}. It will continue evolving while you were away.");
            AdvanceWorld(SimulationConfig.ExploreMinutes);
            return true;
        }

        public void VisitTown()
        {
            var region = Regions[Player.CurrentRegion];
            var discoveredSettlements = region.Settlements.Values.Where(s => s.Discovered).ToList();
            
            if (discoveredSettlements.Count == 0)
            {
                Log(LogCategory.Player, "You have not yet discovered any settlements in this region. Explore to find towns!");
                return;
            }

            SettlementState selectedSettlement;
            if (discoveredSettlements.Count == 1)
            {
                selectedSettlement = discoveredSettlements[0];
                Log(LogCategory.Player, $"You fast travel to {selectedSettlement.Definition.Name}.");
            }
            else
            {
                // Show multiple settlement options
                if (!ShowLogs || AutoResolveEncounters)
                {
                    selectedSettlement = discoveredSettlements[Rng.Next(discoveredSettlements.Count)];
                    Log(LogCategory.Player, $"You fast travel to {selectedSettlement.Definition.Name}.");
                }
                else
                {
                    Console.WriteLine();
                    Console.WriteLine("Discovered Settlements:");
                    for (int i = 0; i < discoveredSettlements.Count; i++)
                    {
                        Console.WriteLine($"[{i + 1}] {discoveredSettlements[i].Definition.Name}");
                    }

                    while (true)
                    {
                        Console.Write("Choose destination: ");
                        var input = Console.ReadLine();
                        if (int.TryParse(input, out var selection) && selection >= 1 && selection <= discoveredSettlements.Count)
                        {
                            selectedSettlement = discoveredSettlements[selection - 1];
                            Log(LogCategory.Player, $"You fast travel to {selectedSettlement.Definition.Name}.");
                            break;
                        }

                        Console.WriteLine("Invalid selection. Please enter a valid settlement number.");
                    }

                    Console.WriteLine();
                }
            }

            Log(LogCategory.Player, "You arrive in town and listen for rumors.");
            AdvanceWorld(60);
            Log(LogCategory.Player, "Merchants haggle openly and faction agents watch for trouble.");
            Player.AddItem("RumorFragment", 1);

            if (ShowLogs && !AutoResolveEncounters)
                OfferTownQuests();
            else
                AutoAcceptTownQuests();

            HandleTurnInRequests();
            CompleteQuestsInTown();
        }

