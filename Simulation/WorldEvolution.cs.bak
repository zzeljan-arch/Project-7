        public double Amount { get; set; }

        public override string ToString() => $"{SourceName} ({SourceType})";
    }

    public class ZoneEvolutionBarState
    {
        public ZoneEvolutionBarDefinition Definition { get; set; }
        public double Value { get; private set; }
        public ZoneEvolutionMilestone CurrentMilestone { get; private set; }
        public bool HasReachedMax { get; private set; }
        public List<string> ModificationHistory { get; private set; } = new();

        public ZoneEvolutionBarState(ZoneEvolutionBarDefinition definition)
        {
            Definition = definition;
            Value = definition.StartingValue;
            CurrentMilestone = CalculateMilestone(Value);
        }

        public void AddInfluence(ZoneEvolutionInfluence influence, WorldState world)
        {
            if (HasReachedMax && influence.Amount > 0)
                return;

            var previousValue = Value;
            var previousMilestone = CurrentMilestone;
            
            Value = Math.Max(Definition.MinValue, Math.Min(Definition.MaxValue, Value + influence.Amount));
            CurrentMilestone = CalculateMilestone(Value);

            if (Value != previousValue)
            {
                LogInfluence(influence, previousValue, Value, world);
            }

            if (CurrentMilestone != previousMilestone)
            {
                LogMilestoneReached(world);
                Definition.OnMilestoneReached?.Invoke(world, CurrentMilestone);
            }

            if (Value >= Definition.MaxValue && !HasReachedMax)
            {
                HasReachedMax = true;
                Definition.OnMaxReached?.Invoke(world);
            }
        }

        private ZoneEvolutionMilestone CalculateMilestone(double value)
        {
            var range = Definition.MaxValue - Definition.MinValue;
            var progress = (Value - Definition.MinValue) / range;
            
            if (progress >= 0.76) return ZoneEvolutionMilestone.Milestone4;
            if (progress >= 0.51) return ZoneEvolutionMilestone.Milestone3;
            if (progress >= 0.26) return ZoneEvolutionMilestone.Milestone2;
            return ZoneEvolutionMilestone.Milestone1;
        }

        private void LogInfluence(ZoneEvolutionInfluence influence, double prevValue, double newValue, WorldState world)
        {
            var message = $"[ZoneEvolution] {Definition.Name}: {prevValue:F1} → {newValue:F1} ({(influence.Amount > 0 ? "+" : "")}{influence.Amount:F1} from {influence})";
            world?.Log(LogCategory.Simulation, message);
            ModificationHistory.Add(message);
        }

        private void LogMilestoneReached(WorldState world)
        {
            if (world?.ShowLogs == true)
            {
                var originalColor = Console.ForegroundColor;
                Console.ForegroundColor = ConsoleColor.Magenta;
                Console.WriteLine("\n" + new string('=', 50));
                Console.WriteLine($"{Definition.Name.ToUpper()}");
                Console.WriteLine($"MILESTONE {(int)CurrentMilestone} REACHED");
                Console.WriteLine(Definition.Description);
                Console.WriteLine(new string('=', 50) + "\n");
                Console.ForegroundColor = originalColor;
            }

            var historyMessage = $"[MILESTONE] {Definition.Name} - Milestone {(int)CurrentMilestone}";
            world?.Log(LogCategory.Simulation, historyMessage);
        }

        public override string ToString() => $"{Definition.Name}: {Value:F1} (Milestone {(int)CurrentMilestone})";
    }

