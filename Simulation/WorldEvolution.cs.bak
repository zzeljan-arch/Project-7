        {
            // TODO: Implement quest turnin with new QuestLine system
        }

        private void OfferTownQuests()
        {
            // TODO: Implement quest offering with new QuestLine system
            Log(LogCategory.Player, "The town is quiet today. No new opportunities present themselves.");
        }

        private void AutoAcceptTownQuests()
        {
            // TODO: Implement auto quest acceptance with new QuestLine system
        }

        public void VisitMarketplace()
        {
            var region = Regions[Player.CurrentRegion];
            var discoveredSettlements = region.Settlements.Values.Where(s => s.Discovered).ToList();
            
            if (discoveredSettlements.Count == 0)
            {
                Log(LogCategory.Player, "There is no marketplace here. You must discover a settlement first by exploring.");
                return;
            }

            var settlement = discoveredSettlements.Count == 1 
                ? discoveredSettlements[0]
                : discoveredSettlements[Rng.Next(discoveredSettlements.Count)];

            Log(LogCategory.Player, $"You browse the marketplace in {settlement.Definition.Name}.");
            AdvanceWorld(45);
            var item = ItemRegistry.AllItems[Rng.Next(ItemRegistry.AllItems.Count)];
            var price = Economy.MarketPrices[item.Id];
            Log(LogCategory.Player, $"A merchant offers {item.Name} for {price:F0} gold.");
            if (Player.Gold >= price)
            {
                Player.SpendGold(price);
                Player.AddItem(item.Id, 1);
                Log(LogCategory.Player, $"You purchase {item.Name}.");
            }
            else
            {
                Log(LogCategory.Player, "You do not have enough gold.");
            }
        }

        public void InventorySummary()
        {
            Log(LogCategory.Player, $"Gold: {Player.Gold:F0}");
            if (Player.Inventory.Count == 0)
            {
                Log(LogCategory.Player, "Inventory is empty.");
                return;
            }

            foreach (var kvp in Player.Inventory)
            {
                var item = ItemRegistry.GetItem(kvp.Key);
                Log(LogCategory.Player, $"{kvp.Value}x {item.Name}");
            }
        }

        public void CharacterSummary()
        {
            Log(LogCategory.Player, $"Health: {Player.Health:F0}/{Player.MaxHealth}");
            foreach (var reputation in Player.Reputation)
            {
                Log(LogCategory.Player, $"{reputation.Key}: {reputation.Value:F1}");
            }
        }

        public void QuestLogSummary()
        {
            if (Player.ActiveQuestLines.Count == 0)
            {
                Log(LogCategory.Player, "You have no quest lines in progress.");
            }
            else
            {
                foreach (var questLine in Player.ActiveQuestLines.Where(ql => !ql.Completed))
                {
                    var currentQuestId = questLine.GetCurrentQuestId();
                    var currentQuest = currentQuestId != null ? QuestRegistry.AllQuests.FirstOrDefault(q => q.Id == currentQuestId) : null;
                    Log(LogCategory.Player, $"[ACTIVE] {questLine.Definition.Title}: {currentQuest?.Title ?? "Unknown"}");
                }

                var completedLines = Player.ActiveQuestLines.Where(ql => ql.Completed).ToList();
                if (completedLines.Count > 0)
                {
                    Log(LogCategory.Player, "Completed quest lines:");
                    foreach (var questLine in completedLines)
                    {
                        Log(LogCategory.Player, $"  {questLine.Definition.Title}");
                    }
                }
            }
        }

        public void ReadBook()
        {
            Log(LogCategory.Player, "You sit down to read a book and expand your knowledge.");
            AdvanceWorld(60);
            Player.Reputation[FactionType.Mages] += 0.5;
            Log(LogCategory.Player, "Your understanding of the world deepens.");
        }

        public void Fish()
        {
            var region = Regions[Player.CurrentRegion];
            if (!region.Definition.HasWater)
            {
                Log(LogCategory.Player, "There is nowhere suitable to fish here.");
                return;
            }

            Log(LogCategory.Player, "You cast a line into the water.");
            AdvanceWorld(45);
            if (Rng.Probability(0.6))
            {
                Player.AddItem("FreshFish", 1);
                Log(LogCategory.Player, "You catch some fresh fish.");
            }
            else
            {
                Log(LogCategory.Player, "The fish ignore your bait.");
            }
        }

        public void Camp()
        {
            Log(LogCategory.Player, "You set up camp for the night.");
            AdvanceWorld(8 * 60);
            Player.Heal(SimulationConfig.RestHealPerHour * 8);
            Log(LogCategory.Player, "The night restores your strength.");
        }

        public void Craft()
        {
            Log(LogCategory.Player, "You attempt to craft something useful.");
            AdvanceWorld(90);
            if (Player.Inventory.TryGetValue("IronOre", out var amount) && amount >= 1)
            {
                Player.Inventory["IronOre"] -= 1;
                Player.AddItem("IronIngot", 1);
                Log(LogCategory.Player, "You smelt iron ore into an iron ingot.");
            }
            else
            {
                Log(LogCategory.Player, "You lack the materials to craft anything meaningful.");
            }
        }

        public void PerformAutomaticAction(bool questMode = false)
        {
            if (questMode)
            {
                PerformQuestFocusedAction();
                return;
            }

            if (Player.Health < Player.MaxHealth * 0.3)
            {
                Log(LogCategory.Simulation, "Automatic action: rest because health is low.");
                Rest();
                return;
            }

            if (Rng.Probability(0.55))
            {
                Log(LogCategory.Simulation, "Automatic action: explore.");
                Explore();
                return;
            }

            if (Rng.Probability(0.15))
            {
                Log(LogCategory.Simulation, "Automatic action: visit town.");
                VisitTown();
                return;
            }

            if (Rng.Probability(0.1))
            {
                Log(LogCategory.Simulation, "Automatic action: fish.");
                Fish();
                return;
            }

            Log(LogCategory.Simulation, "Automatic action: craft.");
            Craft();
        }

        public void PerformQuestFocusedAction()
        {
            if (Player.Health <= 0)
                return;

            if (Player.Health < Player.MaxHealth * 0.2)
            {
                Log(LogCategory.Player, "[QUEST] Resting to heal.");
                Rest();
                return;
            }

            // TODO: Implement quest-focused action with new QuestLine system
            if (Player.ActiveQuestLines.Count == 0)
            {
                Log(LogCategory.Player, "[QUEST] No active quest lines.");
                return;
            }

            Log(LogCategory.Player, $"[QUEST] Following active quest line...");
            Explore();
        }

        private void UpdateFactionInfluence(FactionType faction, double amount)
        {
            if (!Factions.ContainsKey(faction))
                return;

            Factions[faction].Influence = Math.Max(0, Factions[faction].Influence + amount);
        }

        public void ModifyReputation(FactionType faction, double amount)
        {
            Player.Reputation[faction] = Math.Max(-50, Math.Min(50, Player.Reputation[faction] + amount));
            Log(LogCategory.Simulation, $"Reputation with {faction} changed by {amount:F1}.");
        }

        private void ApplyActionProgression(RegionState regionState, PlayerAction action, double multiplier = 1.0)
        {
            if (action is PlayerAction.Raid or PlayerAction.Defend or PlayerAction.Fight or PlayerAction.Help)
            {
                if (regionState.ProgressionBars.TryGetValue("BanditClearance", out var clearanceBar))
                    clearanceBar.AddProgress(6.0 * multiplier);

                // EventBar effects for Help and Defend
                if (action == PlayerAction.Help)
                {
                    AddEventBarProgress(regionState, "MerchantCaravan", 3.0 * multiplier);
                    AddEventBarProgress(regionState, "FarmersNeed", 2.0 * multiplier);
                    AddEventBarProgress(regionState, "TempleActivity", 1.0 * multiplier);
                }
                else if (action == PlayerAction.Defend)
                {
                    AddEventBarProgress(regionState, "RangerActivity", 4.0 * multiplier);
                    AddEventBarProgress(regionState, "BanditPatrol", -3.0 * multiplier);
                }
                else if (action is PlayerAction.Raid or PlayerAction.Fight)
                {
                    AddEventBarProgress(regionState, "RangerActivity", 5.0 * multiplier);
                    AddEventBarProgress(regionState, "BanditPatrol", -5.0 * multiplier);
                }
                return;
            }

            if (action is PlayerAction.Research or PlayerAction.Corrupt or PlayerAction.Negotiate or PlayerAction.Investigate or PlayerAction.ReadBook)
            {
                if (regionState.ProgressionBars.TryGetValue("MagicalAwareness", out var arcaneBar))
                    arcaneBar.AddProgress(4.0 * multiplier);

                // EventBar effects for investigation and research
                if (action == PlayerAction.Investigate)
                {
                    AddEventBarProgress(regionState, "RangerActivity", 5.0 * multiplier);
                    AddEventBarProgress(regionState, "BanditPatrol", -6.0 * multiplier);
                }
                else if (action is PlayerAction.Research or PlayerAction.ReadBook or PlayerAction.Negotiate)
                {
                    AddEventBarProgress(regionState, "TempleActivity", 3.0 * multiplier);
                }
                return;
            }

            if (action == PlayerAction.Explore)
            {
                if (regionState.ProgressionBars.TryGetValue("BanditClearance", out var clearanceBar))
                    clearanceBar.AddProgress(2.0 * multiplier);
                AddEventBarProgress(regionState, "MerchantCaravan", 1.0 * multiplier);
                AddEventBarProgress(regionState, "RangerActivity", 1.0 * multiplier);
            }
        }

        private void AddEventBarProgress(RegionState region, string barId, double amount)
        {
            if (region.EventBars.TryGetValue(barId, out var bar))
            {
                bar.AddProgress(amount);
            }
        }

        public void PerformPlayerAction(RegionId region, PlayerAction action)
        {
            LogProgressionBars($"before player action {action}");

            if (!Regions.ContainsKey(region))
            {
                Log(LogCategory.Player, "That region is not available in this campaign.");
                return;
            }

            var regionState = Regions[region];
            Log(LogCategory.Player, $"You take action {action} in {regionState.Definition.Name}.");

            var influences = EvolutionRules.CalculateActionInfluence(region, action);
            foreach (var influence in influences)
            {
                if (!Regions.TryGetValue(influence.TargetRegion, out var affected))
                    continue;

                var originalTier = affected.CurrentTier;
                var originalPath = affected.CurrentPath;

                if (affected.CurrentTier == WorldTier.Tier1)
                {
                    double upgradeChance = 0.10 + influence.TierChanceDelta;
                    if (Rng.Probability(upgradeChance))
                    {
                        affected.CurrentTier = WorldTier.Tier2;
                        Log(LogCategory.Simulation, $"{affected.Definition.Name} advanced {originalTier} -> {affected.CurrentTier} due to {action}.");
                    }
                }

                if (Rng.Probability(influence.PathChangeChance))
                {
                    var chosenPath = EvolutionRules.ChooseWeightedPath(affected.RegionId, action, Rng);
                    if (chosenPath != affected.CurrentPath)
                    {
                        affected.CurrentPath = chosenPath;
                        Log(LogCategory.Simulation, $"{affected.Definition.Name} shifted from {originalPath} to {chosenPath} because of {action}.");
                    }
                }

                ApplyActionProgression(affected, action, influence.TargetRegion == region ? 1.0 : 0.5);
            }

            AdvanceWorld(30);
            CompleteQuestsInTown();
            LogProgressionBars($"after player action {action}");
        }

        public override string ToString()
        {
            var sb = new StringBuilder();
            sb.AppendLine($"Time: {Clock.CurrentTime}");
            sb.AppendLine($"Player Region: {Player.CurrentRegion}");
            sb.AppendLine($"Health: {Player.Health:F0}/{Player.MaxHealth}, Gold: {Player.Gold:F0}");
            sb.AppendLine("Regions:");
            foreach (var region in Regions.Values)
            {
                sb.AppendLine($"  {region.Definition.Name}: {region.CurrentPath} (Tier {(int)region.CurrentTier})");
            }
            return sb.ToString();
        }

