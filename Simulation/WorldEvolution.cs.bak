        public SettlementState(SettlementDefinition definition)
        {
            Id = definition.Id;
            Definition = definition;
            Discovered = false;
            Population = definition.PopulationStart;
            Wealth = definition.WealthStart;
            Safety = definition.SafetyStart;
            MerchantActivity = 0;

            foreach (var buildingId in definition.InitialBuildings)
            {
                Buildings[buildingId] = new SettlementBuilding { Id = buildingId, Name = buildingId, Active = true, Level = 1 };
            }

            AvailableQuestLineIds = new List<string>(definition.InitialQuestLineIds);
        }

        public void Discover()
        {
            Discovered = true;
        }

        public void ModifyWealth(double amount)
        {
            Wealth = Math.Max(0, Math.Min(100, Wealth + amount));
        }

        public void ModifySafety(double amount)
        {
            Safety = Math.Max(0, Math.Min(100, Safety + amount));
        }

        public void ModifyMerchantActivity(double amount)
        {
            MerchantActivity = Math.Max(0, Math.Min(100, MerchantActivity + amount));
        }
    }

    // ===== EVENTBAR EXPANSION =====

    public class EventBarCompletion
    {
        public List<string> UnlockedEncounterIds { get; set; } = new();
        public List<string> UnlockedQuestLineIds { get; set; } = new();
        public List<string> SettlementEffects { get; set; } = new();
        public List<(string SettlementId, string EffectType, double Amount)> SettlementModifications { get; set; } = new();
        public List<(string ZoneBarId, double Amount)> ZoneEvolutionInfluences { get; set; } = new();
    }

    public class EventBarDefinition
    {
        public string Id { get; set; }
        public string Name { get; set; }
        public string Description { get; set; }
        public string Category { get; set; }
        public double StartingValue { get; set; }
        public double DecayAmount { get; set; }
        public double Threshold { get; set; }
        public double MinValue { get; set; }
        public double MaxValue { get; set; }
        public int CheckFrequency { get; set; }
        public List<string> PrerequisiteEventBarIds { get; set; } = new();
        public int CooldownTurns { get; set; }
        public bool Repeatable { get; set; }
        public EventBarCompletion OnCompletion { get; set; } = new();
        public Func<WorldState, bool> CanProgress { get; set; }
    }

    public class EventBarState
    {
        public EventBarDefinition Definition { get; set; }
        public double Value { get; private set; }
        public bool Completed { get; private set; }
        public int TurnsSinceCompletion { get; private set; }
        public bool HasBeenTouched { get; internal set; }
        private bool _completionProcessed = false;

        public EventBarState(EventBarDefinition definition)
        {
            Definition = definition;
            Value = definition.StartingValue;
            Completed = false;
            TurnsSinceCompletion = -1;
            HasBeenTouched = false;
            _completionProcessed = false;
        }

        public void AddProgress(double amount)
        {
            if (Completed && !Definition.Repeatable)
                return;

            double previousValue = Value;
            Value = Math.Max(Definition.MinValue, Math.Min(Definition.MaxValue, Value + amount));
            HasBeenTouched = true;

            if (Value >= Definition.Threshold && !Completed)
            {
                Completed = true;
                TurnsSinceCompletion = 0;
                _completionProcessed = false;
            }
        }

        public void ApplyDecay()
        {
            if (Completed && !Definition.Repeatable)
                return;

            Value = Math.Max(Definition.MinValue, Value - Definition.DecayAmount);
            HasBeenTouched = true;

            // For repeatable bars, reset completion when value drops below threshold
            if (Definition.Repeatable && Completed && Value < Definition.Threshold)
            {
                Completed = false;
                TurnsSinceCompletion = -1;
                _completionProcessed = false;
            }
        }

        public void UpdateCooldown()
        {
            if (Completed && TurnsSinceCompletion >= 0)
                TurnsSinceCompletion++;
        }

        public void ResetCompletion()
        {
            if (Definition.Repeatable)
            {
                Completed = false;
                TurnsSinceCompletion = -1;
                _completionProcessed = false;
            }
        }

        public bool ShouldProcessCompletion()
        {
            return Completed && !_completionProcessed;
        }

        public void MarkCompletionProcessed()
        {
            _completionProcessed = true;
        }
    }

    // ===== PLAYER STATE UPDATED =====

    public class PlayerState
    {
        public RegionId CurrentRegion { get; set; }
        public double Health { get; set; }
        public double MaxHealth { get; set; }
        public double Gold { get; set; }
        public Dictionary<string, int> Inventory { get; set; } = new();
        public Dictionary<FactionType, double> Reputation { get; set; } = new();
        public List<QuestLineState> ActiveQuestLines { get; set; } = new();
        public List<string> DiscoveredSettlementIds { get; set; } = new();

        public PlayerState(RegionId startingRegion)
        {
            CurrentRegion = startingRegion;
            MaxHealth = 100;
            Health = MaxHealth;
            Gold = SimulationConfig.DefaultStartingGold;
            foreach (FactionType faction in Enum.GetValues(typeof(FactionType)))
                Reputation[faction] = 0;
        }

        public void AddItem(string id, int quantity)
        {
            if (!Inventory.ContainsKey(id))
                Inventory[id] = 0;
            Inventory[id] += quantity;
        }

        public bool SpendGold(double amount)
        {
            if (Gold < amount)
                return false;
            Gold -= amount;
            return true;
        }

        public void Heal(double amount)
        {
            Health = Math.Min(MaxHealth, Health + amount);
        }

        public void Damage(double amount)
        {
            Health = Math.Max(0, Health - amount);
        }
    }

    public class EconomyState
    {
        public Dictionary<string, double> MarketPrices { get; set; } = new();
        public double RegionalWealth { get; set; }

        public EconomyState()
        {
            RegionalWealth = 100;
        }

        public void UpdatePrices(DeterministicRandom rng)
        {
            foreach (var key in MarketPrices.Keys.ToList())
            {
                double volatility = (rng.Next(21) - 10) / 100.0 * SimulationConfig.MarketVolatility;
                MarketPrices[key] = Math.Max(1, MarketPrices[key] * (1 + volatility));
            }
        }
    }

    public class LongTermEventDefinition
    {
        public string Id { get; set; }
        public string Name { get; set; }
        public Func<WorldState, bool> Condition { get; set; }
        public Action<WorldState> OnTrigger { get; set; }
        public bool HasTriggered { get; set; }
    }

