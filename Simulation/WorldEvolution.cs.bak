    public static class EvolutionRules
    {
        private static readonly Dictionary<RegionId, List<EvolutionPath>> RegionPaths = new()
        {
            { RegionId.NorthernRealm, new() { EvolutionPath.AgeOfRaiders, EvolutionPath.EternalWinter, EvolutionPath.Ragnarok, EvolutionPath.UndeadNorth } },
            { RegionId.DarkForest, new() { EvolutionPath.PrimordialJungle, EvolutionPath.CorruptedAbyss, EvolutionPath.ElvenEnclave, EvolutionPath.CursedWildlands } },
            { RegionId.DesertKingdom, new() { EvolutionPath.AgeOfMerchants, EvolutionPath.AgeOfPharaohs, EvolutionPath.ElementalCatastrophe, EvolutionPath.ShadowAndSecrets } },
            { RegionId.Swamp, new() { EvolutionPath.PrimordialBog, EvolutionPath.PlaguePestilence, EvolutionPath.MonsterDominion, EvolutionPath.MysticalAwakening } },
            { RegionId.Highlands, new() { EvolutionPath.DwarvenProsperity, EvolutionPath.AsceticHermitage, EvolutionPath.DragonRoost, EvolutionPath.CorruptionBlight } },
            { RegionId.InfernalLands, new() { EvolutionPath.DemonicDominion, EvolutionPath.VolcanicCatastrophe, EvolutionPath.DemonicElementalFusion, EvolutionPath.EternalForge } },
            { RegionId.ArcaneEmpire, new() { EvolutionPath.ArcaneAscendance, EvolutionPath.KnowledgeHoarding, EvolutionPath.TechnoMagicalSynthesis, EvolutionPath.CorruptionDecay } }
        };

        private static readonly Dictionary<PlayerAction, (HashSet<PathTrait> Favor, HashSet<PathTrait> Disfavor)> ActionTraits = new()
        {
            { PlayerAction.Purify, (new() { PathTrait.Nature, PathTrait.Order }, new() { PathTrait.Corruption }) },
            { PlayerAction.Raid, (new() { PathTrait.War, PathTrait.Corruption }, new() { PathTrait.Knowledge }) },
            { PlayerAction.Research, (new() { PathTrait.Knowledge, PathTrait.Magic }, new() { PathTrait.War }) },
            { PlayerAction.Negotiate, (new() { PathTrait.Trade, PathTrait.Order }, new() { PathTrait.Corruption }) },
            { PlayerAction.Corrupt, (new() { PathTrait.Corruption, PathTrait.Magic }, new() { PathTrait.Order }) },
            { PlayerAction.Explore, (new() { PathTrait.Nature, PathTrait.Magic }, new() { PathTrait.Corruption }) },
            { PlayerAction.Defend, (new() { PathTrait.Order, PathTrait.War }, new() { PathTrait.Corruption }) }
        };

        public static List<RegionId> GetAdjacentRegions(RegionId regionId)
        {
            return regionId switch
            {
                RegionId.NorthernRealm => new() { RegionId.DarkForest, RegionId.Highlands, RegionId.ArcaneEmpire },
                RegionId.DarkForest => new() { RegionId.NorthernRealm, RegionId.Swamp, RegionId.ArcaneEmpire },
                RegionId.DesertKingdom => new() { RegionId.Swamp, RegionId.Highlands, RegionId.InfernalLands },
                RegionId.Swamp => new() { RegionId.DarkForest, RegionId.DesertKingdom, RegionId.Highlands },
                RegionId.Highlands => new() { RegionId.NorthernRealm, RegionId.Swamp, RegionId.DesertKingdom, RegionId.InfernalLands },
                RegionId.InfernalLands => new() { RegionId.Highlands, RegionId.DesertKingdom, RegionId.ArcaneEmpire },
                RegionId.ArcaneEmpire => new() { RegionId.NorthernRealm, RegionId.DarkForest, RegionId.InfernalLands },
                _ => new()
            };
        }

        public static List<ActionInfluence> CalculateActionInfluence(RegionId sourceRegion, PlayerAction action)
        {
            var influences = new List<ActionInfluence>
            {
                new() { TargetRegion = sourceRegion, TierChanceDelta = 0.12, PathChangeChance = 0.35, SourceAction = action }
            };

            foreach (var neighbor in GetAdjacentRegions(sourceRegion))
            {
                influences.Add(new() { TargetRegion = neighbor, TierChanceDelta = 0.08, PathChangeChance = 0.20, SourceAction = action });
            }

            return influences;
        }

        public static List<EvolutionPath> GetPathsForRegion(RegionId regionId)
        {
            return RegionPaths.TryGetValue(regionId, out var paths) ? paths : new List<EvolutionPath>();
        }

        public static EvolutionPath ChooseWeightedPath(RegionId regionId, PlayerAction action, DeterministicRandom rng)
        {
            var weights = new Dictionary<EvolutionPath, int>();
            var paths = RegionPaths[regionId];
            var traits = ActionTraits.ContainsKey(action) ? ActionTraits[action] : (new HashSet<PathTrait>(), new HashSet<PathTrait>());

            var (favorTraits, disfavorTraits) = traits;
            foreach (var path in paths)
            {
                int weight = 10;
                bool pathIsWar = path.ToString().Contains("Raid") || path.ToString().Contains("War");
                bool pathIsMagic = path.ToString().Contains("Magic") || path.ToString().Contains("Arcane") || path.ToString().Contains("Mystical");
                bool pathIsCorruption = path.ToString().Contains("Corrupt") || path.ToString().Contains("Shadow") || path.ToString().Contains("Demonic") || path.ToString().Contains("Decay");

                if (favorTraits.Contains(PathTrait.War) && pathIsWar)
                    weight += 10;
                if (favorTraits.Contains(PathTrait.Magic) && pathIsMagic)
                    weight += 10;
                if (favorTraits.Contains(PathTrait.Corruption) && pathIsCorruption)
                    weight += 10;
                if (disfavorTraits.Contains(PathTrait.Corruption) && pathIsCorruption)
                    weight -= 5;

                weights[path] = Math.Max(1, weight);
            }

            int total = weights.Values.Sum();
            int pick = rng.Next(total);
            foreach (var kvp in weights)
            {
                if (pick < kvp.Value)
                    return kvp.Key;
                pick -= kvp.Value;
            }

            return paths.First();
        }
    }

