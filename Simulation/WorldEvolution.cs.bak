    public static class SimulationLog
    {
        private static readonly object LockObj = new object();

        public static void Write(LogCategory category, string message)
        {
            lock (LockObj)
            {
                var original = Console.ForegroundColor;
                Console.ForegroundColor = category == LogCategory.Player ? ConsoleColor.White : ConsoleColor.DarkGray;
                string prefix = category == LogCategory.Player ? "[EVENT]" : "[SIM]";
                Console.WriteLine($"{prefix} {message}");
                Console.ForegroundColor = original;
            }
        }

        public static void WriteBlank() => Console.WriteLine();
    }

    public class WorldClock
    {
        public int Day { get; private set; } = 1;
        public int Hour { get; private set; } = 8;
        public int Minute { get; private set; } = 0;

        public void AdvanceMinutes(int minutes)
        {
            Minute += minutes;
            Hour += Minute / 60;
            Minute %= 60;
            Day += Hour / 24;
            Hour %= 24;
        }

        public string CurrentTime => $"Day {Day}, {Hour:D2}:{Minute:D2}";
    }

