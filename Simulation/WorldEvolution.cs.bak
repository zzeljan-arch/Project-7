        public Action<WorldState> OnDecay { get; set; }
    }

    public class ProgressionBarState
    {
        public ProgressionBarDefinition Definition { get; set; }
        public double Value { get; private set; }
        public bool Completed { get; private set; }
        public bool HasBeenTouched { get; private set; }

        public ProgressionBarState(ProgressionBarDefinition definition)
        {
            Definition = definition;
            Value = definition.MinValue;
            HasBeenTouched = false;
        }

        public void AddProgress(double amount)
        {
            if (Completed)
                return;

            var previousValue = Value;
            Value = Math.Min(Definition.MaxValue, Value + amount);
            if (Value != previousValue)
            {
                HasBeenTouched = true;
                LogColoredBarUpdate($"+{amount:F1}", previousValue, Value);
            }

            if (Value >= Definition.Threshold)
            {
                Completed = true;
                Definition.OnComplete?.Invoke(WorldState.CurrentGlobalState);
                LogColoredCompletion();
            }
        }

        public void ApplyDecay()
        {
            if (Completed)
                return;

            var previousValue = Value;
            Value = Math.Max(Definition.MinValue, Value - Definition.DecayAmount);
            if (Value != previousValue)
            {
                HasBeenTouched = true;
                LogColoredBarUpdate($"decay", previousValue, Value);
            }
            Definition.OnDecay?.Invoke(WorldState.CurrentGlobalState);
        }

        private void LogColoredBarUpdate(string action, double prevValue, double newValue)
        {
            var state = WorldState.CurrentGlobalState;
            if (state?.ShowLogs == true)
            {
                var originalColor = Console.ForegroundColor;
                Console.ForegroundColor = ConsoleColor.Cyan;
                Console.WriteLine($"[BAR] {Definition.Name} {action}: {prevValue:F1} → {newValue:F1}/{Definition.Threshold:F0}");
                Console.ForegroundColor = originalColor;
            }
            state?.SimulationHistory.Add($"[BAR] {Definition.Name} {action}: {prevValue:F1} → {newValue:F1}/{Definition.Threshold:F0}");
        }

        private void LogColoredCompletion()
        {
            var state = WorldState.CurrentGlobalState;
            if (state?.ShowLogs == true)
            {
                var originalColor = Console.ForegroundColor;
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine($"[COMPLETE] {Definition.Name} reached threshold!");
                Console.ForegroundColor = originalColor;
            }
            state?.SimulationHistory.Add($"[COMPLETE] {Definition.Name} reached threshold!");
        }

        public override string ToString() => $"{Definition.Name}: {Value:F1}/{Definition.Threshold}";
    }

